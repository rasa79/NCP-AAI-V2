# NVIDIA RAG Certification Learning Package - Environment Variables

# OpenAI API Key (required for LLM access)
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith Configuration (optional, for tracing and monitoring)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=nvidia-rag-certification

# NVIDIA API Keys (optional, for NVIDIA NIM and platform services)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Vector Store Configuration (optional)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENVIRONMENT=your_pinecone_env_here

# Model Configuration
DEFAULT_MODEL=gpt-4
DEFAULT_EMBEDDING_MODEL=text-embedding-ada-002

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
